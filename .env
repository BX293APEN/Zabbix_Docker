# =============================================================================
# .env  -  Zabbix Docker 環境設定ファイル
#
# バージョンアップ時は ZABBIX_VERSION のみ変更すればOK
# 起動コマンド: docker compose up --build -d
# =============================================================================

# ---------- コンテナ名 ----------
ZABBIX_CONTAINER_NAME=Zabbix_Server
DB_CONTAINER_NAME=Zabbix_DB
WEB_CONTAINER_NAME=Zabbix_Web

# ---------- Dockerfile の場所 ----------
# docker-compose.yml からの相対パス、または絶対パス
DOCKERFILE_DIR=.                    # Dockerfile が置いてあるディレクトリ
DOCKERFILE=Dockerfile               # Dockerfile のファイル名
ENTRY_POINT=entry.sh

# ---------- Zabbix イメージバージョン ----------
# https://hub.docker.com/r/zabbix/zabbix-server-mysql/tags で確認
# ここを変えるだけで server / web / Dockerfile ARG すべてに反映される
ZABBIX_VERSION=alpine-7.4-latest

# ---------- MySQL イメージバージョン ----------
MYSQL_VERSION=8.0

# ---------- DB 接続情報 ----------
MYSQL_DATABASE=zabbix
MYSQL_USER=zabbix
MYSQL_PASSWORD=zabbixpass
MYSQL_ROOT_PASSWORD=rootpass

# ---------- Zabbix サーバ ----------
ZBX_SERVER_HOST=zabbix-server
DB_SERVER_HOST=zabbix-db
DB_SERVER_PORT=3306

# ---------- Web UI ----------
PHP_TZ=Asia/Tokyo
WEB_PORT=8080

# ---------- Zabbix トラッパーポート ----------
ZBX_TRAPPER_PORT=10051

# ---------- Zabbix 初期化 SQL ----------
# Zabbix 7.x : create.sql.gz (schema+dataが統合)
# Zabbix 6.x : schema.sql.gz と data.sql.gz が別ファイル (entry.sh の修正も必要)
ZBX_CREATE_SQL=/usr/share/doc/zabbix-server-mysql/create.sql.gz
# 複数ファイルはコンマ区切りで指定可能:
# ZBX_CREATE_SQL=schema.sql.gz,data.sql.gz,custom.sql.gz


# 初回ログイン : ユーザ名 : Admin / パスワード : zabbix