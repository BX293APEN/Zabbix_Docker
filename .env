# =============================================================================
# .env  -  Zabbix Docker 環境設定ファイル
#
# バージョンアップ時は ZABBIX_VERSION のみ変更すればOK
# =============================================================================
ZABBIX_CONTAINER_NAME=Zabbix_Server
DB_CONTAINER_NAME=Zabbix_DB
WEB_CONTAINER_NAME=Zabbix_Web

# ---------- Zabbix イメージバージョン ----------
# https://hub.docker.com/r/zabbix/zabbix-server-mysql/tags で確認
ZABBIX_VERSION=alpine-7.0-latest

# ---------- MySQL イメージバージョン ----------
MYSQL_VERSION=8.0

# ---------- DB 接続情報 ----------
MYSQL_DATABASE=zabbix
MYSQL_USER=zabbix
MYSQL_PASSWORD=zabbixpass
MYSQL_ROOT_PASSWORD=rootpass

# ---------- Zabbix サーバ ----------
ZBX_SERVER_HOST=zabbix-server
DB_SERVER_HOST=zabbix-db
DB_SERVER_PORT=3306

# ---------- Web UI ----------
PHP_TZ=Asia/Tokyo
WEB_PORT=8080          # ホスト側ポート → コンテナの 8080 に転送

# ---------- Zabbix トラッパーポート ----------
ZBX_TRAPPER_PORT=10051
